# =============================================================================
# SiteMap Monorepo - Central Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# This is the single source of truth for all environment variables.
# Used by: web, mobile (dev), powersync-server, docker-compose files
# =============================================================================

# ====================
# Database
# ====================
DATABASE_URL=postgres://user:password@your-hetzner-host:5432/sitemap

# ====================
# Authentication
# ====================
JWT_SECRET=your-jwt-secret-here

# ====================
# PowerSync
# ====================
POWERSYNC_PORT=6061
POWERSYNC_LOG_LEVEL=info
POWERSYNC_SLOT_NAME=powersync_sitemap_slot
POWERSYNC_PUBLICATION=powersync_sitemap_pub

# ====================
# Web
# ====================
WEB_PORT=3000

# ====================
# Mobile
# ====================
MOBILE_API_URL=http://localhost:3000
MOBILE_POWERSYNC_URL=http://localhost:6061
PROD_API_URL=https://sitemap.yourdomain.com
PROD_POWERSYNC_URL=https://sync.sitemap.yourdomain.com

# ====================
# Environment
# ====================
NODE_ENV=development
