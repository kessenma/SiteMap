{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "kill-metro": "lsof -ti:8081 | xargs kill -9 2>/dev/null || echo 'No process on port 8081'",
    "start": "pnpm run kill-metro && rock start --port 8081",
    "start:device": "pnpm run kill-metro && rock start --host 0.0.0.0 --port 8081",
    "lint": "eslint .",
    "test": "jest",
    "ios": "rock run:ios --device \"iPhone 17 Pro\"",
    "android": "rock run:android",
    "check-types": "tsc --noEmit"
  },
